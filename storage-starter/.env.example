# Network: "testnet" or "mainnet" (default: testnet)
NETWORK=testnet

# Storage mode: "turbo" or "standard" (default: turbo)
# Turbo: higher fees, faster/more reliable
# Standard: lower fees (currently unavailable on some networks)
STORAGE_MODE=turbo

# Your private key (NEVER commit real keys!)
PRIVATE_KEY=your_private_key_here

# Optional: Gas configuration
# GAS_PRICE=3000000000000
# GAS_LIMIT=2000000

# Optional: Retry configuration
# MAX_RETRIES=3
# MAX_GAS_PRICE=3000000000000
